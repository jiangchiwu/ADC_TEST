; *************************************************************
; *** Scatter-Loading Description File generated by uVision ***
; *************************************************************
;
; 内存布局说明:
;   LR_IROM1  : Flash 0x08000000, 128KB (STM32H750)
;   RW_IRAM1  : DTCM 0x20000000, 128KB — 栈 + FFT 缓冲 + 关键 RW/ZI
;   RW_IRAM2  : AXI SRAM 0x24000000, 512KB — ADC DMA 缓冲 + 事件队列
;   RW_IRAM3  : SRAM4(D3域) 0x38000000, 32KB — ADC3 DMA 缓冲(Non-Cacheable)
;
; 栈放置策略:
;   栈 (STACK section) 放在 DTCM (RW_IRAM1 起始), 0 延迟, 无 DMA 争用
;   DTCM 剩余空间放 FFT 缓冲等对延迟敏感的数据
;   AXI SRAM 放大块 DMA 缓冲和事件队列

LR_IROM1 0x08000000 0x00020000  {    ; load region size_region (Flash 128KB)
  ER_IROM1 0x08000000 0x00020000  {  ; load address = execution address
   *.o (RESET, +First)
   *(InRoot$$Sections)
   .ANY (+RO)
  }

  ; --- DTCM: 栈 + FFT 缓冲 + 关键数据 (0 等待, CPU 专用总线) ---
  RW_IRAM1 0x20000000 0x00020000  {  ; DTCM 128KB
   *.o (STACK)                        ; 栈放 DTCM 最前面, 0 延迟无 DMA 争用
   .ANY (+RW +ZI)
  }

  ; --- AXI SRAM: 大块 DMA 缓冲 + 事件队列 (通过 AXI 总线共享) ---
  RW_IRAM2 0x24000000 0x00080000  {  ; AXI SRAM 512KB
   .ANY (+RW +ZI)
  }
}

